{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen:api": "openapi-typescript ../SluiceBase.Api/openapi.json -o src/api/schema.ts",

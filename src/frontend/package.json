    "@mantine/notifications": "^9.3.1",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@uiw/codemirror-themes-all": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@xyflow/react": "^12.11.0",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
